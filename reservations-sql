SELECT
       RESERVE.EMAIL AS 'Email',
       RESERVE.LASTNAME AS 'Last Name(*)',
       RESERVE.FIRSTNAME AS 'First Name',
       RESERVE.PHONE1 AS 'Telephone',
       RESERVE.STREET AS 'Address Line 1',
       RESERVE.CITY AS 'City',
       RESERVE.ZIPCODE AS 'Postal Code',
       RESERVE.COUNTRY AS 'Country Code',
       RESERVE.STATE AS 'Country Subdivision Code',
       RESERVE.GUESTNOTES AS 'Internal Guest Notes',
       RESERVE.CHECKIN AS 'Arrival Date(*)',
       RESERVE.CHECKOUT AS 'Departure Date(*)',
       RESERVE.ADULTS + RESERVE.CHILD AS 'Person Counts(*)',
       RESERVE.ADULTS AS 'Adult Count(*)',
       RESERVE.CHILD AS 'Child Count(*)',
       RESERVE.NOTES AS 'Reservation Notes',
       RESERVE.CONFNUM AS 'Confirmation Code',
       SUM(RESERVETOTALSTAY.TOTALSTAY) AS 'Total Price',
       RESERVE.DEPOSITAMT AS 'Prepaid Amount',
       RESERVE.BEDTYPE AS 'Allocated Room Category(*)',
       ROOMBOOK.ROOMNUMBER AS 'Allocated Room Number',
       RESERVE.RATE_REQ AS 'Allocated Rate',

       RESERVE.VIPNUMBER AS 'GuestProfileID',
       RESERVE.INTERN_NUM AS 'Reference Number',
       RESERVE.ENTRYDATE AS 'Entry Date',
       RESERVE.ROOMS AS 'ROOMS',
       SUM(RESERVETOTALSTAY.ROOMAMOUNT) AS 'Total_Room_Charges',
       SUM(RESERVETOTALSTAY.DAILYAMOUNT) AS 'Daily Charges',
       SUM(RESERVETOTALSTAY.ROOMTAXAMOUNT) AS 'Total_Taxes',
       ROUND(SUM(RESERVETOTALSTAY.ROOMAMOUNT)/RESERVE.NIGHTS,2) AS 'ADR_Without_Tax',
       RESERVE.CCD_TYPE AS 'Hold Type',
       CASE(RESERVE.RESERVESTATUS)
            WHEN 'R' THEN 'Reserved'
            WHEN 'I' THEN 'Inhouse'
            WHEN 'P' THEN 'Preserved'
            WHEN 'C' THEN 'cancelled'
            WHEN 'W' THEN 'Waitlist'
       END AS 'Status Code',
       RESERVE.USER1 AS 'UserField 1',
       RESERVE.USER2 AS 'UserField 2',
       RESERVE.NOTES AS 'Staff Notes',
       RESERVE.GUESTNOTES AS 'Guest Notes'

FROM RESERVE
LEFT OUTER JOIN ROOMBOOK ON RESERVE.CONFNUM = ROOMBOOK.CONFNUM
JOIN RESERVETOTALSTAY ON RESERVE.CONFNUM = RESERVETOTALSTAY.CONFNUM
WHERE RESERVESTATUS IN ('R','P','W')
GROUP BY RESERVE.CONFNUM,RESERVE.INTERN_NUM,RESERVE.FIRSTNAME,RESERVE.DEPOSITAMT,RESERVE.RATE_REQ,RESERVE.LASTNAME,RESERVE.CHECKIN,RESERVE.BEDTYPE,RESERVE.CHECKOUT,RESERVE.ENTRYDATE,ROOMBOOK.ROOMNUMBER,RESERVE.DEPOSITAMT,RESERVE.ADULTS,RESERVE.CHILD,RESERVE.USER1,RESERVE.USER2,RESERVE.NOTES,RESERVE.GUESTNOTES,RESERVE.RESERVESTATUS,RESERVE.CCD_TYPE,RESERVE.PERCENT,RESERVE.STREET,RESERVE.CITY,RESERVE.STATE,RESERVE.ZIPCODE,RESERVE.COUNTRY,RESERVE.PHONE1,RESERVE.EMAIL,RESERVE.VIPNUMBER,RESERVE.INTERN_NUM,RESERVE.ROOMS,RESERVE.NIGHTS

UNION ALL 

SELECT 
       VIPFILE.EMAIL AS 'Email',
       FOLIOHD.LASTNAME AS 'Last Name(*)',
       FOLIOHD.FIRSTNAME AS 'First Name',
       FOLIOHD.PHONE1 AS 'Telephone',
       FOLIOHD.STREET AS 'Address Line 1',
       FOLIOHD.CITY AS 'City',
       FOLIOHD.ZIPCODE AS 'Postal Code',
       FOLIOHD.COUNTRY AS 'Country Code',
       FOLIOHD.STATE AS 'Country Subdivision Code',
       ' ' AS 'Internal Guest Notes',
       FOLIOHD.CHECKIN AS 'Arrival Date(*)',
       FOLIOHD.CHECKOUT AS 'Departure Date(*)',
       FOLIOHD.ADULTS + FOLIOHD.CHILD AS 'Person Counts(*)',
       FOLIOHD.ADULTS AS 'Adult Count(*)',
       FOLIOHD.CHILD AS 'Child Count(*)',
       FOLIOHD.NOTES AS 'Reservation Notes',
       FOLIOHD.CONFNUM AS 'Confirmation Code',
       SUM(FOLIOTOTALSTAY.TOTALSTAY) AS 'Total Price',
       (SELECT SUM(FOLIOTRN.CREDIT) FROM FOLIOTRN WHERE FOLIOTRN.TRANTYPE = 001 AND FOLIOTRN.NUMBER = FOLIOHD.NUMBER) AS 'Prepaid Amount',
       ROOMS.BEDTYPE AS 'Allocated Room Category(*)',
       FOLIOHD.ORIGROOM AS 'Allocated Room Number',
       FOLIOHD.RATE_REQ AS 'Allocated Rate',

       FOLIOHD.VIPNUMBER AS 'GuestProfileID',
       FOLIOHD.INTERN_NUM AS 'Reference Number',
       FOLIOHD.ENTRYDATE AS 'Entry Date',
       RESERVE.ROOMS AS 'ROOMS',
       SUM(FOLIOTOTALSTAY.ROOMAMOUNT) AS 'Total_Room_Charges',
       SUM(FOLIOTOTALSTAY.DAILYAMOUNT) AS 'Daily Charges',
       SUM(FOLIOTOTALSTAY.ROOMTAXAMOUNT) AS 'Total_Taxes',
       ROUND(SUM(FOLIOTOTALSTAY.ROOMAMOUNT)/FOLIOHD.NIGHTS, 2) AS 'ADR_Without_Tax',
       FOLIOHD.CCD_TYPE AS 'Hold Type',
       'Inhouse' AS 'Status Code',
       FOLIOHD.USER1 AS 'UserField 1',
       FOLIOHD.USER2 AS 'UserField 2',
       FOLIOHD.NOTES AS 'Staff Notes',
       ' ' AS 'Guest Notes'

FROM FOLIOHD
LEFT JOIN ROOMS ON FOLIOHD.ORIGROOM = ROOMS.ROOMNUMBER
LEFT JOIN VIPFILE ON FOLIOHD.VIPNUMBER = VIPFILE.NUMBER
LEFT JOIN RESERVE ON FOLIOHD.CONFNUM = RESERVE.CONFNUM
JOIN FOLIOTOTALSTAY ON FOLIOHD.NUMBER = FOLIOTOTALSTAY.NUMBER
WHERE FOLIOHD.FIRSTNAME <> ''
GROUP BY 
    FOLIOHD.CONFNUM,
    FOLIOHD.VIPNUMBER,
    FOLIOHD.INTERN_NUM,
    FOLIOHD.FIRSTNAME,
    FOLIOHD.LASTNAME,
    FOLIOHD.CHECKIN,
    FOLIOHD.CHECKOUT,
    FOLIOHD.ENTRYDATE,
    ROOMS.BEDTYPE,
    FOLIOHD.ORIGROOM,
    FOLIOHD.RATE_REQ,
    FOLIOHD.NIGHTS,
    FOLIOHD.ADULTS,
    FOLIOHD.CHILD,
    FOLIOHD.CCD_TYPE,
    FOLIOHD.STREET,
    FOLIOHD.CITY,
    FOLIOHD.STATE,
    FOLIOHD.ZIPCODE,
    FOLIOHD.COUNTRY,
    FOLIOHD.PHONE1,
    VIPFILE.EMAIL,
    FOLIOHD.USER1,
    FOLIOHD.USER2,
    FOLIOHD.NOTES,
    RESERVE.ROOMS,
    FOLIOHD.NUMBER;
